PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only secret (Settings → API → service_role). Bypasses RLS — never expose to the client.
# Required to sign URLs for the private course-videos Storage bucket.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Auth email hook (src/pages/api/auth-email.ts) — server-only.
# Resend API key scoped to the cpd.themoleclinic.co.uk sending domain.
RESEND_API_KEY=re_your-resend-key-here
# Secret generated by Supabase when you create the Send Email Hook (format: v1,whsec_...).
SEND_EMAIL_HOOK_SECRET=v1,whsec_your-hook-secret-here

# Azure Blob Storage for private course videos (src/lib/azure.ts) — server-only.
AZURE_STORAGE_ACCOUNT=your-storage-account-name
AZURE_STORAGE_CONTAINER=course-videos
AZURE_STORAGE_KEY=your-storage-account-key

# Dynamics 365 / Dataverse contact sync (src/lib/dataverse.ts) — server-only.
# From the Azure AD app registration + your Dataverse environment.
DATAVERSE_URL=https://yourorg.crm11.dynamics.com
DATAVERSE_TENANT_ID=your-azure-ad-tenant-id
DATAVERSE_CLIENT_ID=your-app-registration-client-id
DATAVERSE_CLIENT_SECRET=your-app-registration-client-secret
# Shared secret you invent; also set as the x-webhook-secret header on the Supabase webhook.
DATAVERSE_WEBHOOK_SECRET=invent-a-long-random-string
