---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import { getServerClient } from '../lib/supabase'

// Validate session server-side with getUser() (re-validates JWT, not just cookie read)
const supabase = getServerClient(Astro.request, Astro.cookies)
const { data: { user }, error: userError } = await supabase.auth.getUser()

if (!user || userError) {
  return Astro.redirect('/login')
}

// Fetch profile
const { data: profile } = await supabase
  .from('profiles')
  .select('full_name, email, profession')
  .eq('id', user.id)
  .single()

// Fetch published modules
const { data: modulesRaw } = await supabase
  .from('modules')
  .select('id, slug, title, summary, order_index, duration_minutes')
  .eq('published', true)
  .order('order_index')

// Fetch this user's completions
const { data: completionsRaw } = await supabase
  .from('module_completions')
  .select('module_id')
  .eq('user_id', user.id)

const completedIds = new Set((completionsRaw ?? []).map((c) => c.module_id))

const modules = (modulesRaw ?? []).map((m) => ({
  ...m,
  completed: completedIds.has(m.id),
}))

const nextModule = modules.find((m) => !m.completed)
const displayName = profile?.full_name || profile?.email || user.email
const completedCount = modules.filter((m) => m.completed).length
---
<Layout title="Dashboard" description="Your TMC Skin Cancer CPD dashboard.">
  <section class="bg-tmc-primary text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
      <p class="text-tmc-light/80 text-sm mb-1">Welcome back</p>
      <h1 class="text-3xl sm:text-4xl font-light text-white">{displayName}</h1>
      {profile?.profession && (
        <p class="text-tmc-light/80 text-sm mt-1">{profile.profession}</p>
      )}
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      {modules.length === 0 ? (
        <!-- Modules not yet published -->
        <div class="bg-tmc-surface rounded-2xl p-8 text-center">
          <p class="text-tmc-text font-light text-lg mb-2">Programme coming soon</p>
          <p class="text-sm text-tmc-text/70">
            The modules are being prepared. We'll email you when the first one is ready.
          </p>
        </div>
      ) : (
        <>
          <!-- Progress summary -->
          <div class="flex items-center gap-6 mb-8">
            <div>
              <p class="text-3xl font-light text-tmc-primary">{completedCount}/{modules.length}</p>
              <p class="text-sm text-tmc-text/70">modules complete</p>
            </div>
            {nextModule && (
              <a
                href={`/modules/${nextModule.slug}`}
                class="ml-auto inline-block bg-tmc-accent hover:bg-tmc-primary text-white text-sm font-medium px-6 py-2.5 rounded-lg transition-colors"
              >
                Continue →
              </a>
            )}
            {completedCount === modules.length && modules.length > 0 && (
              <p class="ml-auto text-sm font-medium text-green-700 bg-green-50 border border-green-200 px-4 py-2 rounded-lg">
                Programme complete
              </p>
            )}
          </div>

          <!-- Module list -->
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {modules.map((mod) => (
              <li class={`flex items-center gap-4 rounded-xl border p-4 ${
                mod.completed
                  ? 'border-green-200 bg-green-50'
                  : 'border-gray-100 bg-white'
              }`}>
                <div class={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium flex-shrink-0 ${
                  mod.completed
                    ? 'bg-green-100 text-green-700'
                    : 'bg-tmc-surface text-tmc-primary'
                }`}>
                  {mod.order_index}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-tmc-text text-sm truncate">{mod.title}</p>
                  {mod.summary && (
                    <p class="text-xs text-tmc-text/60 truncate">{mod.summary}</p>
                  )}
                </div>
                {mod.duration_minutes && (
                  <span class="text-xs text-tmc-text/50 flex-shrink-0">{mod.duration_minutes} min</span>
                )}
                <span class={`text-xs font-medium px-2.5 py-1 rounded-full flex-shrink-0 ${
                  mod.completed
                    ? 'bg-green-100 text-green-700'
                    : 'bg-tmc-surface text-tmc-text/60'
                }`}>
                  {mod.completed ? 'Complete' : 'Not started'}
                </span>
                <!-- /modules/[slug] is week 2 — link stubs to coming-soon for now -->
                <a
                  href={`/modules/${mod.slug}`}
                  class="text-xs text-tmc-accent hover:text-tmc-primary underline underline-offset-2 flex-shrink-0"
                >
                  {mod.completed ? 'Review' : 'Start'}
                </a>
              </li>
            ))}
          </ul>
        </>
      )}

      <!-- Sign out -->
      <div class="mt-10 pt-8 border-t border-gray-100">
        <a
          href="/logout"
          class="text-sm text-tmc-text/60 hover:text-tmc-text underline underline-offset-2 transition-colors"
        >
          Sign out
        </a>
      </div>
    </div>
  </section>
</Layout>
