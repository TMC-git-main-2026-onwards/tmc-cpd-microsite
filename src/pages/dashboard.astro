---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import { getServerClient } from '../lib/supabase'
import { getVideoSasUrl } from '../lib/azure'

// Validate session server-side with getUser() (re-validates JWT, not just cookie read)
const supabase = getServerClient(Astro.request, Astro.cookies)
const { data: { user }, error: userError } = await supabase.auth.getUser()

if (!user || userError) {
  return Astro.redirect('/login')
}

// Fetch profile
const { data: profile } = await supabase
  .from('profiles')
  .select('full_name, email, profession')
  .eq('id', user.id)
  .single()

// Fetch published modules
const { data: modulesRaw } = await supabase
  .from('modules')
  .select('id, slug, title, summary, order_index, duration_minutes, video_url')
  .eq('published', true)
  .order('order_index')

// Fetch this user's completions
const { data: completionsRaw } = await supabase
  .from('module_completions')
  .select('module_id')
  .eq('user_id', user.id)

const completedIds = new Set((completionsRaw ?? []).map((c) => c.module_id))

// Build view models with sequential gating + signed video URLs.
// A module unlocks once the previous one is complete (the first is always open).
// We only sign URLs for unlocked modules that actually have a video, so locked
// content is never exposed to the client. Videos live in a private Azure Blob
// container; we mint a short-lived SAS URL per unlocked module.
let prevCompleted = true
const modules = []
for (const m of modulesRaw ?? []) {
  const completed = completedIds.has(m.id)
  const unlocked = m.order_index === 1 || prevCompleted
  let videoUrl: string | null = null
  if (unlocked && m.video_url) {
    try {
      videoUrl = getVideoSasUrl(m.video_url, 60 * 60) // 1 hour
    } catch (err) {
      console.error(`Failed to sign video for module ${m.slug}:`, err)
    }
  }
  modules.push({ ...m, completed, unlocked, videoUrl })
  prevCompleted = completed
}

const displayName = profile?.full_name || profile?.email || user.email
const completedCount = modules.filter((m) => m.completed).length
const total = modules.length
const allComplete = total > 0 && completedCount === total
---
<Layout title="Dashboard" description="Your TMC Skin Cancer CPD dashboard.">
  <section class="bg-tmc-primary text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
      <p class="text-tmc-light/80 text-sm mb-1">Welcome back</p>
      <h1 class="text-3xl sm:text-4xl font-light text-white">{displayName}</h1>
      {profile?.profession && (
        <p class="text-tmc-light/80 text-sm mt-1">{profile.profession}</p>
      )}
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      {total === 0 ? (
        <div class="bg-tmc-surface rounded-2xl p-8 text-center">
          <p class="text-tmc-text font-light text-lg mb-2">Programme coming soon</p>
          <p class="text-sm text-tmc-text/70">
            The modules are being prepared. We'll email you when the first one is ready.
          </p>
        </div>
      ) : (
        <>
          <!-- Progress summary -->
          <div class="flex items-center gap-6 mb-8">
            <div>
              <p class="text-3xl font-light text-tmc-primary">{completedCount}/{total}</p>
              <p class="text-sm text-tmc-text/70">modules complete</p>
            </div>
            {allComplete && (
              <p class="ml-auto text-sm font-medium text-green-700 bg-green-50 border border-green-200 px-4 py-2 rounded-lg">
                Programme complete 🎉
              </p>
            )}
          </div>

          <!-- Module list -->
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {modules.map((mod) => (
              <li class={`flex items-center gap-4 rounded-xl border p-4 transition-colors ${
                mod.completed
                  ? 'border-green-200 bg-green-50'
                  : mod.unlocked
                    ? 'border-gray-100 bg-white'
                    : 'border-gray-100 bg-gray-50'
              }`}>
                <!-- Status indicator: green tick when complete (not colour alone),
                     number when available, lock when gated. -->
                <div class={`w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 ${
                  mod.completed
                    ? 'bg-green-600 text-white'
                    : mod.unlocked
                      ? 'bg-tmc-surface text-tmc-primary'
                      : 'bg-gray-100 text-gray-400'
                }`}>
                  {mod.completed ? (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" role="img" aria-label="Completed">
                      <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.5 7.5a1 1 0 01-1.42 0l-3.5-3.5a1 1 0 011.42-1.42l2.79 2.79 6.79-6.79a1 1 0 011.42 0z" clip-rule="evenodd" />
                    </svg>
                  ) : mod.unlocked ? (
                    <span class="text-sm font-medium">{mod.order_index}</span>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" role="img" aria-label="Locked">
                      <path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v2H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2V9a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 6V5a2 2 0 10-4 0v2h4z" clip-rule="evenodd" />
                    </svg>
                  )}
                </div>

                <div class="flex-1 min-w-0">
                  <p class={`font-medium text-sm truncate ${mod.unlocked ? 'text-tmc-text' : 'text-gray-400'}`}>{mod.title}</p>
                  {mod.summary && (
                    <p class="text-xs text-tmc-text/60 truncate">{mod.summary}</p>
                  )}
                </div>

                {mod.duration_minutes && mod.unlocked && (
                  <span class="text-xs text-tmc-text/50 flex-shrink-0">{mod.duration_minutes} min</span>
                )}

                <!-- Action -->
                {mod.completed && mod.videoUrl ? (
                  <button
                    type="button"
                    class="watch-btn text-xs font-medium text-green-700 hover:text-green-800 underline underline-offset-2 flex-shrink-0"
                    data-video-url={mod.videoUrl}
                    data-module-id={mod.id}
                    data-module-title={mod.title}
                  >
                    Rewatch
                  </button>
                ) : mod.completed ? (
                  <span class="text-xs font-medium text-green-700 flex-shrink-0">Completed</span>
                ) : mod.unlocked && mod.videoUrl ? (
                  <button
                    type="button"
                    class="watch-btn bg-tmc-accent hover:bg-tmc-primary text-white text-xs font-medium px-4 py-2 rounded-lg transition-colors flex-shrink-0"
                    data-video-url={mod.videoUrl}
                    data-module-id={mod.id}
                    data-module-title={mod.title}
                  >
                    ▶ Watch video
                  </button>
                ) : mod.unlocked ? (
                  <span class="text-xs text-tmc-text/50 flex-shrink-0">Video coming soon</span>
                ) : (
                  <span class="text-xs text-gray-400 flex-shrink-0">Locked</span>
                )}
              </li>
            ))}
          </ul>

          <p class="text-xs text-tmc-text/50 mt-4">
            Watch each video to the end to mark the module complete and unlock the next one.
          </p>
        </>
      )}

      <!-- Sign out -->
      <div class="mt-10 pt-8 border-t border-gray-100">
        <a
          href="/logout"
          class="text-sm text-tmc-text/60 hover:text-tmc-text underline underline-offset-2 transition-colors"
        >
          Sign out
        </a>
      </div>
    </div>
  </section>

  <!-- Video modal (pop-out) -->
  <div
    id="video-modal"
    class="hidden fixed inset-0 z-50 items-center justify-center bg-black/70 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="video-modal-title"
  >
    <div class="bg-white rounded-2xl overflow-hidden w-full max-w-3xl shadow-xl">
      <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100">
        <h3 id="video-modal-title" class="text-sm font-medium text-tmc-text truncate pr-4">Module video</h3>
        <button
          type="button"
          id="video-modal-close"
          class="text-tmc-text/50 hover:text-tmc-text text-2xl leading-none flex-shrink-0"
          aria-label="Close video"
        >&times;</button>
      </div>
      <div class="bg-black">
        <video
          id="modal-video"
          controls
          controlslist="nodownload"
          playsinline
          preload="metadata"
          class="w-full h-auto block aspect-video"
        ></video>
      </div>
      <p id="video-modal-status" class="text-xs text-tmc-text/60 px-5 py-3"></p>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById('video-modal') as HTMLDivElement
  const video = document.getElementById('modal-video') as HTMLVideoElement
  const titleEl = document.getElementById('video-modal-title') as HTMLElement
  const statusEl = document.getElementById('video-modal-status') as HTMLParagraphElement
  const closeBtn = document.getElementById('video-modal-close') as HTMLButtonElement

  let currentModuleId: string | null = null
  let completedThisOpen = false

  const defaultStatus = 'Watch to the end to mark this module complete.'

  function openModal(url: string, moduleId: string, title: string) {
    currentModuleId = moduleId
    completedThisOpen = false
    titleEl.textContent = title
    statusEl.textContent = defaultStatus
    // Autoplay on pop-out with a single play() call (chaining a second play()
    // off a rejected one races and fails). Browsers allow sound only during an
    // active user gesture; if there isn't one, start MUTED (always permitted) so
    // the video still plays, with the speaker control to add sound.
    const hasGesture = !!(navigator.userActivation && navigator.userActivation.isActive)
    video.muted = !hasGesture
    video.src = url
    modal.classList.remove('hidden')
    modal.classList.add('flex')
    document.body.style.overflow = 'hidden'
    video.play()
      .then(() => {
        if (video.muted) statusEl.textContent = 'Playing muted — tap the speaker icon to turn sound on.'
      })
      .catch(() => { statusEl.textContent = 'Press the ▶ play button to start the video.' })
  }

  function closeModal() {
    video.pause()
    video.removeAttribute('src')
    video.load()
    modal.classList.add('hidden')
    modal.classList.remove('flex')
    document.body.style.overflow = ''
    // If a module was completed during this view, refresh so the tick + unlock show.
    if (completedThisOpen) window.location.reload()
  }

  document.querySelectorAll<HTMLButtonElement>('.watch-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      openModal(
        btn.dataset.videoUrl!,
        btn.dataset.moduleId!,
        btn.dataset.moduleTitle ?? 'Module video',
      )
    })
  })

  // Mark complete when the video finishes.
  video.addEventListener('ended', async () => {
    if (!currentModuleId) return
    statusEl.textContent = 'Saving your progress…'
    try {
      const res = await fetch('/api/complete-module', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ moduleId: currentModuleId }),
      })
      if (res.ok) {
        completedThisOpen = true
        statusEl.textContent = '✓ Module complete — the next one is now unlocked.'
      } else {
        statusEl.textContent = 'We couldn’t save your progress. Please try again.'
      }
    } catch {
      statusEl.textContent = 'We couldn’t save your progress. Please try again.'
    }
  })

  closeBtn.addEventListener('click', closeModal)
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal() })
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal()
  })
</script>
