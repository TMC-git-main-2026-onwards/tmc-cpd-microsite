---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Check your email"
  description="You've signed up for the TMC Skin Cancer CPD programme. Check your email to confirm."
>
  <section class="bg-tmc-primary text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
      <h1 class="text-3xl sm:text-4xl font-light text-white mb-3">Check your email.</h1>
      <p class="text-tmc-light font-light text-lg max-w-xl">
        We've sent you a confirmation link. Click it to activate your account and access the
        CPD programme.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-tmc-text/70 text-sm mb-8">
        Already confirmed?
      </p>
      <a
        href="/login"
        class="inline-block bg-tmc-accent hover:bg-tmc-primary text-white font-medium px-8 py-3.5 rounded-lg transition-colors text-sm"
      >
        Sign in →
      </a>
    </div>
  </section>
</Layout>
