---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="You're on the list"
  description="Thanks for joining the TMC Skin Cancer CPD waitlist. We'll be in touch."
>
  <section class="bg-tmc-primary text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
      <h1 class="text-3xl sm:text-4xl font-light text-white mb-3">You're on the list.</h1>
      <p class="text-tmc-light font-light text-lg max-w-xl">
        We'll email you the moment the CPD programme goes live.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-tmc-text mb-8 text-lg font-light">
        While you wait — here's what's inside the programme.
      </p>
      <a
        href="/programme"
        class="inline-block bg-tmc-accent hover:bg-tmc-primary text-white font-medium px-8 py-3.5 rounded-lg transition-colors text-sm"
      >
        See the programme →
      </a>
    </div>
  </section>
</Layout>
