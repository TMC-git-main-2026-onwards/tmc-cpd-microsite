---
import Layout from '../layouts/Layout.astro';
---
<!-- TODO: legal review before launch -->
<Layout
  title="Privacy"
  description="How The Mole Clinic collects and uses your data when you create a CPD account."
>
  <section class="bg-tmc-primary text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
      <h1 class="text-3xl sm:text-4xl font-light text-white mb-3">Privacy notice</h1>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <p class="text-tmc-text leading-relaxed mb-4">
        We collect your email address solely to notify you when the CPD programme launches.
      </p>
      <p class="text-tmc-text leading-relaxed mb-4">
        <span class="font-medium">Lawful basis:</span> Consent. By creating an account
        and checking the consent box, you consent to us contacting you about the programme
        and related updates.
      </p>
      <p class="text-tmc-text leading-relaxed mb-4">
        <span class="font-medium">Your right to withdraw:</span> You can unsubscribe at any time
        by replying to any email we send, or by contacting us at{' '}
        <span class="text-tmc-text/60">[email TBC]</span>.
      </p>
      <p class="text-tmc-text leading-relaxed mb-4">
        <span class="font-medium">Data sharing:</span> We will not share your email address with
        third parties.
      </p>
      <p class="text-tmc-text leading-relaxed mb-4">
        <span class="font-medium">Data controller:</span> The Mole Clinic.
        <a
          href="https://themoleclinic.co.uk"
          target="_blank"
          rel="noopener noreferrer"
          class="text-tmc-accent hover:text-tmc-primary underline underline-offset-2 transition-colors"
        >
          themoleclinic.co.uk
        </a>
      </p>
      <p class="text-xs text-tmc-text/50 mt-8 border-t border-gray-100 pt-6">
        This is a placeholder notice. Full GDPR-compliant privacy policy to be completed prior
        to launch.
      </p>
    </div>
  </section>
</Layout>
