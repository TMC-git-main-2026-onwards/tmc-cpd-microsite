---
export const prerender = false

import { getServerClient } from '../../lib/supabase'

const url = new URL(Astro.request.url)
const code = url.searchParams.get('code')
const tokenHash = url.searchParams.get('token_hash')
const type = url.searchParams.get('type')

// Only allow same-site relative paths as the post-login destination, so a
// crafted ?next=https://evil.example (or //evil.example, or javascript:...)
// can't turn our trusted domain into an open-redirect / phishing bounce.
function safeNext(raw: string | null): string {
  return raw && /^\/(?!\/)/.test(raw) ? raw : '/dashboard'
}
const next = safeNext(url.searchParams.get('next'))

// Server-side handling for links that carry their token in the query string:
//  - ?code=        PKCE auth code (same-browser flows)
//  - ?token_hash=  one-time OTP hash (works from any browser)
if (code) {
  const supabase = getServerClient(Astro.request, Astro.cookies)
  const { error } = await supabase.auth.exchangeCodeForSession(code)
  if (!error) return Astro.redirect(next)
}
if (tokenHash && type) {
  const supabase = getServerClient(Astro.request, Astro.cookies)
  const { error } = await supabase.auth.verifyOtp({ token_hash: tokenHash, type: type as any })
  if (!error) return Astro.redirect(next)
}

// Otherwise the tokens arrive in the URL hash (implicit flow), which the server
// never sees — so finish sign-in on the client below.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>Signing you in…</title>
  </head>
  <body style="font-family:-apple-system,Segoe UI,Roboto,sans-serif;color:#0e7490;display:flex;min-height:60vh;align-items:center;justify-content:center;">
    <p>Signing you in…</p>
    <script>
      import { getBrowserClient } from '../../lib/supabase'

      const rawNext = new URLSearchParams(window.location.search).get('next')
      // Same-site relative paths only (mirror of the server-side check).
      const next = rawNext && /^\/(?!\/)/.test(rawNext) ? rawNext : '/dashboard'
      const supabase = getBrowserClient()

      ;(async () => {
        let session = null

        // A link carrying tokens in the hash always wins — even if a different
        // account is already signed in on this device (e.g. clicking a magic
        // link while logged in as someone else). Set it explicitly first.
        if (window.location.hash.includes('access_token')) {
          const hash = new URLSearchParams(window.location.hash.slice(1))
          const access_token = hash.get('access_token')
          const refresh_token = hash.get('refresh_token')
          if (access_token && refresh_token) {
            const { data } = await supabase.auth.setSession({ access_token, refresh_token })
            session = data.session
          }
        }

        // No hash tokens (already consumed by detectSessionInUrl, or none) —
        // fall back to any existing session.
        if (!session) {
          ;({ data: { session } } = await supabase.auth.getSession())
        }

        window.location.replace(session ? next : '/login?error=auth_error')
      })()
    </script>
  </body>
</html>
