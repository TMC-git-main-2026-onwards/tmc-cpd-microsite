---
interface Props {
  heading?: string;
}
const { heading = 'Create your account' } = Astro.props;
---
<section class="bg-tmc-light rounded-2xl p-8 sm:p-10 max-w-xl mx-auto">
  <h2 class="text-2xl font-light text-tmc-primary mb-2">{heading}</h2>
  <p class="text-tmc-text text-sm mb-6">
    Join thousands of physios building their skin cancer confidence. Free, online, CPD-accredited.
  </p>

  <form id="waitlist-form" class="flex flex-col gap-4" novalidate>
    <div class="flex flex-col gap-1">
      <label for="wl-email" class="text-sm font-medium text-tmc-text">Your email</label>
      <input
        id="wl-email"
        type="email"
        name="email"
        required
        placeholder="you@clinic.co.uk"
        class="border border-tmc-mid rounded-lg px-4 py-2.5 text-sm text-tmc-text placeholder-tmc-mid focus:outline-none focus:ring-2 focus:ring-tmc-accent bg-white"
      />
    </div>

    <div class="flex flex-col gap-1">
      <label for="wl-profession" class="text-sm font-medium text-tmc-text">Profession</label>
      <select
        id="wl-profession"
        name="profession"
        required
        class="border border-tmc-mid rounded-lg px-4 py-2.5 text-sm text-tmc-text focus:outline-none focus:ring-2 focus:ring-tmc-accent bg-white"
      >
        <option value="">Select...</option>
        <option>Physiotherapist</option>
        <option>Sports therapist</option>
        <option>Other healthcare professional</option>
      </select>
    </div>

    <div class="flex flex-col gap-1">
      <label for="wl-password" class="text-sm font-medium text-tmc-text">
        Password
        <span class="font-normal text-tmc-text/60 ml-1">(optional — or we can email you a sign-in link)</span>
      </label>
      <input
        id="wl-password"
        type="password"
        name="password"
        placeholder="Leave blank for magic link"
        autocomplete="new-password"
        class="border border-tmc-mid rounded-lg px-4 py-2.5 text-sm text-tmc-text placeholder-tmc-mid/70 focus:outline-none focus:ring-2 focus:ring-tmc-accent bg-white"
      />
    </div>

    <label class="flex items-start gap-3 cursor-pointer">
      <input
        id="wl-consent"
        type="checkbox"
        name="consent"
        required
        class="mt-0.5 accent-tmc-accent flex-shrink-0"
      />
      <span class="text-sm text-tmc-text">
        I consent to The Mole Clinic contacting me about the CPD programme and related updates.
        I can unsubscribe at any time.
      </span>
    </label>

    <p id="wl-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></p>

    <button
      type="submit"
      id="wl-submit"
      class="w-full bg-tmc-accent hover:bg-tmc-primary text-white font-medium py-3 px-6 rounded-lg transition-colors text-sm disabled:opacity-60 disabled:cursor-not-allowed"
    >
      Sign up
    </button>
  </form>
</section>

<script>
  import { getBrowserClient } from '../lib/supabase'

  const form = document.getElementById('waitlist-form') as HTMLFormElement
  const submitBtn = document.getElementById('wl-submit') as HTMLButtonElement
  const errorEl = document.getElementById('wl-error') as HTMLParagraphElement

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading
    submitBtn.textContent = loading ? 'Please wait…' : 'Sign up'
  }

  function showError(msg: string) {
    errorEl.textContent = msg
    errorEl.classList.remove('hidden')
  }

  function clearError() {
    errorEl.classList.add('hidden')
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    clearError()

    const email = (document.getElementById('wl-email') as HTMLInputElement).value.trim()
    const profession = (document.getElementById('wl-profession') as HTMLSelectElement).value
    const password = (document.getElementById('wl-password') as HTMLInputElement).value
    const consent = (document.getElementById('wl-consent') as HTMLInputElement).checked

    if (!email) { showError('Please enter your email address.'); return }
    if (!profession) { showError('Please select your profession.'); return }
    if (!consent) { showError('Please check the consent box to continue.'); return }

    setLoading(true)

    const supabase = getBrowserClient()
    const redirectTo = `${window.location.origin}/auth/callback`
    const metadata = { profession, marketing_consent: true }

    const { error } = password
      ? await supabase.auth.signUp({
          email,
          password,
          options: { emailRedirectTo: redirectTo, data: metadata },
        })
      : await supabase.auth.signInWithOtp({
          email,
          options: { emailRedirectTo: redirectTo, data: metadata },
        })

    setLoading(false)

    if (error) {
      showError(error.message)
      return
    }

    window.location.href = '/thanks'
  })
</script>
