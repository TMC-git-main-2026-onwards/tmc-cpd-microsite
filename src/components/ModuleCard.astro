---
interface Segment {
  description: string;
  duration: string;
}

interface Props {
  number: number;
  title: string;
  subtitle: string;
  accentBg: string;
  accentText: string;
  dotColor: string;
  segments: Segment[];
  learningOutcome: string;
}

const { number, title, subtitle, accentBg, accentText, dotColor, segments, learningOutcome } = Astro.props;
---
<article class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
  <div class="flex items-center gap-3 mb-4">
    <div
      class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium flex-shrink-0"
      style={`background: ${accentBg}; color: ${accentText};`}
    >
      {number}
    </div>
    <div class="flex-1 min-w-0">
      <p class="font-medium text-tmc-text text-base leading-tight m-0">{title}</p>
      <p class="text-xs text-tmc-text/70 mt-0.5 m-0">{subtitle}</p>
    </div>
    <span
      class="text-xs font-medium px-3 py-1 rounded-lg whitespace-nowrap flex-shrink-0"
      style={`background: ${accentBg}; color: ${accentText};`}
    >
      10 min
    </span>
  </div>

  <ul class="ml-11 flex flex-col gap-2 list-none p-0 m-0 mb-3">
    {segments.map((seg) => (
      <li class="flex items-center gap-2.5">
        <div
          class="w-1.5 h-1.5 rounded-full flex-shrink-0"
          style={`background: ${dotColor};`}
        />
        <span class="text-sm text-tmc-text/80 flex-1">{seg.description}</span>
        <span class="text-xs text-tmc-text/50 whitespace-nowrap">{seg.duration}</span>
      </li>
    ))}
  </ul>

  <div class="ml-11 bg-tmc-surface rounded-lg px-3 py-2">
    <p class="text-xs text-tmc-text/80 m-0">
      <span class="font-medium text-tmc-text">Learning outcome:</span> {learningOutcome}
    </p>
  </div>
</article>
