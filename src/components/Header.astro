---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/programme', label: 'Programme' },
  { href: '/about', label: 'About' },
]

const currentPath = Astro.url.pathname
// session is null for pre-rendered static pages (middleware doesn't run on CDN-served files)
const session = Astro.locals?.session ?? null
// Once signed in, the dashboard replaces the public Programme page, so hide that
// link. On SSR pages we filter here; on static pages the client script below
// removes it when it detects a session.
const visibleLinks = session ? navLinks.filter((l) => l.href !== '/programme') : navLinks
---
<header class="bg-tmc-primary text-white relative">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex-shrink-0" aria-label="The Mole Clinic CPD — home">
      <img src="/logo-white.png" alt="The Mole Clinic" class="h-auto w-44 sm:h-9 sm:w-auto" />
    </a>

    <!-- Mobile menu toggle (hidden on ≥sm where the inline nav shows) -->
    <button
      id="menu-toggle"
      type="button"
      class="sm:hidden inline-flex items-center justify-center p-2 -mr-2 rounded-md hover:bg-white/10 transition-colors"
      aria-label="Open menu"
      aria-controls="main-nav"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Inline row on desktop; full-width dropdown below the bar on mobile -->
    <nav
      id="main-nav"
      aria-label="Main navigation"
      class="hidden sm:block absolute sm:static top-16 inset-x-0 z-50 bg-tmc-primary sm:bg-transparent border-t border-white/10 sm:border-0 shadow-lg sm:shadow-none"
    >
      <ul class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6 text-sm font-medium list-none m-0 p-4 sm:p-0">
        {visibleLinks.map(({ href, label }) => (
          <li data-nav={href}>
            <a
              href={href}
              class={`block py-2 sm:py-0 hover:text-tmc-light transition-colors ${
                currentPath === href ? 'font-semibold sm:font-medium sm:border-b sm:border-white sm:pb-0.5' : 'opacity-90'
              }`}
            >
              {label}
            </a>
          </li>
        ))}

        <!-- Auth nav: server renders based on Astro.locals (works on SSR pages).
             Client script below syncs state on static pages. -->
        <li>
          <div
            id="header-auth"
            data-server-auth={session ? 'authenticated' : 'anonymous'}
            class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4"
          >
            {session ? (
              <>
                <a
                  href="/dashboard"
                  data-auth-el="dashboard"
                  class="block py-2 sm:py-0 opacity-90 hover:text-tmc-light transition-colors"
                >
                  Dashboard
                </a>
                <a
                  href="/logout"
                  data-auth-el="signout"
                  class="block py-2 sm:py-0 opacity-90 hover:text-tmc-light transition-colors"
                >
                  Sign out
                </a>
              </>
            ) : (
              <a
                href="/login"
                data-auth-el="signin"
                class="block py-2 sm:py-0 opacity-90 hover:text-tmc-light transition-colors"
              >
                Sign in
              </a>
            )}
          </div>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  import { getBrowserClient } from '../lib/supabase'

  ;(async () => {
    const authDiv = document.getElementById('header-auth')
    if (!authDiv) return

    const serverState = authDiv.dataset.serverAuth // 'authenticated' | 'anonymous'

    // If this is an SSR page and the server already set the correct state, skip.
    // Only run the client check on static pages (serverState === 'anonymous' but
    // the user might actually be logged in).
    if (serverState === 'authenticated') return

    const supabase = getBrowserClient()
    const { data: { session } } = await supabase.auth.getSession()
    if (!session) return // server and client agree: anonymous

    // Server said anonymous but client has a session — update the nav
    authDiv.innerHTML =
      `<a href="/dashboard" class="block py-2 sm:py-0 opacity-90 hover:text-tmc-light transition-colors">Dashboard</a>` +
      `<a href="/logout" class="block py-2 sm:py-0 opacity-90 hover:text-tmc-light transition-colors">Sign out</a>`

    // Signed in: hide the Programme link (the dashboard replaces it)
    document.querySelector('[data-nav="/programme"]')?.remove()
  })()
</script>

<!-- Mobile nav toggle. Inline (no imports) so it runs immediately. -->
<script is:inline>
  (function () {
    var btn = document.getElementById('menu-toggle')
    var nav = document.getElementById('main-nav')
    if (!btn || !nav) return
    btn.addEventListener('click', function () {
      var nowHidden = nav.classList.toggle('hidden')
      btn.setAttribute('aria-expanded', String(!nowHidden))
      btn.setAttribute('aria-label', nowHidden ? 'Open menu' : 'Close menu')
    })
  })()
</script>
